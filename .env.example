# ──────────────────────────────────────────────────────────────────────────
# TempEdge — Runtime Configuration
# Copy this file to .env and fill in required values.
# All values shown are defaults — only uncomment lines you want to change.
#
# For K8s deployments, secrets are managed via K8s Secret manifests.
# See k8s/secrets/ directory for templates.
# ──────────────────────────────────────────────────────────────────────────

# ── Trading (REQUIRED for live trading) ──────────────────────────────────
# Modes: disabled | dry-run | live
TRADING_MODE=disabled
# Your Polymarket wallet private key (hex, with 0x prefix)
POLYMARKET_PRIVATE_KEY=
# Builder/operator credentials (for gasless relay transactions)
POLYMARKET_BUILDER_ADDRESS=
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=

# ── Trading Risk Controls ────────────────────────────────────────────────
# MAX_POSITION_COST=2.00              # Max USDC per single position
# MAX_DAILY_SPEND=5.00                # Max USDC per day across all trades
# BUY_SIZE=5                          # Shares per buy (0 = auto-calculate)
# MIN_ORDER_VALUE=1.05                # Minimum order value ($1.05 buffer)
# MAX_SPREAD_PCT=0.20                 # Max 20% bid-ask spread to accept
# MIN_ASK_DEPTH=5                     # Min shares available at ask
# CLOB_HOST=https://clob.polymarket.com
# CHAIN_ID=137                        # Polygon mainnet

# ── On-Chain Operations (Redeem) ─────────────────────────────────────────
# POLYGON_RPC_URL=https://polygon.drpc.org  # Polygon RPC for balance checks & tx

# ── Monitoring ───────────────────────────────────────────────────────────
# MONITOR_INTERVAL=15                 # Minutes between monitoring cycles
# FORECAST_SHIFT_THRESHOLD=1.0        # °F change that triggers alert
# PRICE_SPIKE_THRESHOLD=0.05          # 5¢ change that triggers alert
# REBALANCE_THRESHOLD=7.0             # °F change to trigger rebalance sell
# BUY_HOUR_EST=9.5                    # 9:30am ET buy trigger (decimal hours)

# ── Liquidity Streaming ─────────────────────────────────────────────────
# WS_LIQUIDITY_ENABLED=1              # Enable WebSocket liquidity monitoring
# LIQUIDITY_BUY_MODE=threshold        # threshold | best-window
# LIQUIDITY_CHECK_SECS=30             # Seconds between liquidity checks
# LIQUIDITY_WINDOW_MINS=60            # Minutes for best-window tracking
# LIQUIDITY_DEADLINE_HOUR=10.5        # 10:30am ET deadline for illiquid buys
# LIQUIDITY_ALL_REQUIRED=1            # Require ALL positions liquid (vs ANY)

# ── Weather (REQUIRED — at least one source) ─────────────────────────────
# Weather Company API key (primary source)
WC_API_KEY=
# WEATHER_STATION=KLGA                # Weather station code
# WEATHER_LAT=40.7769                 # Station latitude (LaGuardia)
# WEATHER_LON=-73.8740                # Station longitude
# WC_BASE_URL=https://api.weather.com/v3/wx
# OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast  # Free fallback
# WEATHER_RETRIES=2

# ── Polymarket API ───────────────────────────────────────────────────────
# GAMMA_BASE_URL=https://gamma-api.polymarket.com
# SLUG_TEMPLATE=highest-temperature-in-nyc-on-{date}
# MAX_SEARCH_PAGES=4
# SEARCH_PAGE_SIZE=50

# ── Dashboard ────────────────────────────────────────────────────────────
# DASHBOARD_PORT=3000
# DASHBOARD_REFRESH_MS=10000          # Auto-refresh interval (ms)
# DASHBOARD_LIQUIDITY_MS=5000         # Liquidity panel poll interval (ms)
# MANUAL_SELL_ENABLED=0               # Show manual sell buttons (0|1)

# ── VPN (for K8s trading-svc sidecar) ────────────────────────────────────
# NordVPN service credentials (NOT login credentials)
# These go in k8s/secrets/vpn-secret.yaml, not here
# OPENVPN_USER=
# OPENVPN_PASSWORD=

# ── Service Ports (for local development) ────────────────────────────────
# DASHBOARD_SVC_PORT=3000
# LIQUIDITY_SVC_PORT=3001
# MARKET_SVC_PORT=3003
# TRADING_SVC_PORT=3004
# DATA_SVC_PORT=3005
# WEATHER_SVC_PORT=3006
# MONITOR_PORT=3002

# ── Phase Logic ──────────────────────────────────────────────────────────
# PHASE_BUY_DAYS_MIN=2                # Days before target = "buy" phase

# ── Inter-Service Authentication ─────────────────────────────────────────
# Shared secret for service-to-service API calls.
# When set, all POST/PUT/PATCH/DELETE requests between services
# must include an X-Service-Key header matching this value.
# Leave empty to disable auth (development mode).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVICE_AUTH_KEY=
