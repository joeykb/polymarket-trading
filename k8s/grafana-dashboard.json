        { "expr": "sum(rate(weather_svc_http_requests_total[5m])) by (method)", "legendFormat": "weather-svc {{method}}" },
        { "expr": "sum(rate(market_svc_http_requests_total[5m])) by (method)", "legendFormat": "market-svc {{method}}" },
        { "expr": "sum(rate(liquidity_svc_http_requests_total[5m])) by (method)", "legendFormat": "liquidity-svc {{method}}" },
