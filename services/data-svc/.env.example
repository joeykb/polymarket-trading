# TempEdge Data Service
# Port: 3005  |  Manages: SQLite DB, session files, config overrides

# ── Server ────────────────────────────────────────────────────────────
DATA_SVC_PORT=3005

# ── Database ─────────────────────────────────────────────────────────
# DB_PATH=./output/tempedge.db        # SQLite file path
# OUTPUT_DIR=./output                 # Output dir for session files
# CONFIG_OVERRIDES_PATH=./output/admin-overrides.json

# ── Logging ──────────────────────────────────────────────────────────
# LOG_FORMAT=json
# LOG_DEBUG=1
