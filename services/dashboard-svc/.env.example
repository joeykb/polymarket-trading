# TempEdge Dashboard Service
# Port: 3000

# ── Server ────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000

# ── Upstream Services (auto-discovered via K8s DNS in production) ─────
# DATA_SVC_URL=http://data-svc:3005
# TRADING_SVC_URL=http://trading-svc:3004
# LIQUIDITY_SVC_URL=http://liquidity-svc:3001

# ── Logging ──────────────────────────────────────────────────────────
# LOG_FORMAT=json          # Force JSON logs (auto in K8s)
# LOG_DEBUG=1              # Enable debug-level logging
