# TempEdge Trading Service
# Port: 3004  |  Handles: buy, sell, redeem via Polymarket CLOB API

# ── Server ────────────────────────────────────────────────────────────
TRADING_SVC_PORT=3004

# ── Wallet (REQUIRED for live trading) ───────────────────────────────
POLYMARKET_PRIVATE_KEY=           # Ethereum private key (0x...)
TRADING_MODE=disabled             # disabled | dry-run | live

# ── Trading Params ───────────────────────────────────────────────────
MAX_POSITION_COST=2.0             # Max cost per position ($)
MAX_DAILY_SPEND=5.0               # Max total daily spend ($)
BUY_SIZE=0                        # Share quantity (0 = auto-calculate)
MIN_ORDER_VALUE=1.05              # Min order value buffer ($)
MAX_SPREAD_PCT=0.2                # Max bid-ask spread before skipping
MIN_ASK_DEPTH=5                   # Min shares at ask to fill

# ── Polymarket API ───────────────────────────────────────────────────
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137                      # 137 = Polygon mainnet, 80002 = Amoy testnet
# POLYGON_RPC_URL=               # Optional custom RPC

# ── Upstream Services ────────────────────────────────────────────────
# DATA_SVC_URL=http://data-svc:3005
