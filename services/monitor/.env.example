# TRADING_SVC_URL=http://trading-svc:3004
# DATA_SVC_URL=http://data-svc:3005
# LIQUIDITY_SVC_URL=http://liquidity-svc:3001

# ── Logging ──────────────────────────────────────────────────────────
# LOG_FORMAT=json
# LOG_DEBUG=1
