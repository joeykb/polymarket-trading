# TempEdge Weather Service
# Port: 3002  |  Wraps Weather Company (primary) + Open-Meteo (fallback)

# ── Server ────────────────────────────────────────────────────────────
WEATHER_SVC_PORT=3002

# ── Weather Company API ──────────────────────────────────────────────
WC_API_KEY=                       # Weather Company API key
# WC_BASE_URL=https://api.weather.com/v3/wx

# ── Open-Meteo (fallback, no key needed) ─────────────────────────────
# OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast

# ── Station Location (NYC LaGuardia by default) ──────────────────────
# STATION_LAT=40.7769
# STATION_LON=-73.874
# WEATHER_RETRIES=2
